    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.2/codemirror.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.2/mode/sql/sql.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.2/addon/hint/show-hint.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.2/addon/hint/sql-hint.min.js"></script>
    
    <script>
        let columnIndex = <?= count($report['columns'] ?? []) ?>;
        let joinIndex = <?= count($report['joins'] ?? []) ?>;
        let conditionIndex = <?= count($report['conditions'] ?? []) ?>;

        function addColumn() {
            const html = `
                <div class="draggable-item column-item" data-index="${columnIndex}">
                    <div class="row">
                        <div class="col-md-5">
                            <input type="text" class="form-control" 
                                   name="columns[${columnIndex}][column_expression]"
                                   placeholder="Column expression (e.g., table.column)">
                        </div>
                        <div class="col-md-3">
                            <input type="text" class="form-control" 
                                   name="columns[${columnIndex}][alias]"
                                   placeholder="Alias">
                        </div>
                        <div class="col-md-2">
                            <select class="form-control" 
                                    name="columns[${columnIndex}][column_type]">
                                <option value="SELECT">SELECT</option>
                                <option value="CALCULATED">CALCULATED</option>
                                <option value="CONDITIONAL">CONDITIONAL</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <button type="button" class="btn btn-danger btn-sm" onclick="removeColumn(this)">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </div>
                </div>`;
            $('#columnsContainer').append(html);
            columnIndex++;
        }

        function addJoin() {
            const html = `
                <div class="draggable-item join-item" data-index="${joinIndex}">
                    <div class="row">
                        <div class="col-md-2">
                            <select class="form-control" 
                                    name="joins[${joinIndex}][join_type]">
                                <option value="INNER">INNER</option>
                                <option value="LEFT">LEFT</option>
                                <option value="RIGHT">RIGHT</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <select class="form-control join-table" 
                                    name="joins[${joinIndex}][table_name]">
                                <option value="">Select table</option>
                                <?php foreach ($tables as $table): ?>
                                    <option value="<?= $table ?>"><?= $table ?></option>
                                <?php endforeach; ?>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <input type="text" class="form-control" 
                                   name="joins[${joinIndex}][alias]"
                                   placeholder="Alias">
                        </div>
                        <div class="col-md-4">
                            <input type="text" class="form-control" 
                                   name="joins[${joinIndex}][join_condition]"
                                   placeholder="Join condition (e.g., t1.id = t2.table_id)">
                        </div>
                        <div class="col-md-1">
                            <button type="button" class="btn btn-danger btn-sm" onclick="removeJoin(this)">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </div>
                </div>`;
            $('#joinsContainer').append(html);
            joinIndex++;
        }

        function addCondition() {
            const html = `
                <div class="draggable-item condition-item" data-index="${conditionIndex}">
                    <div class="row">
                        <div class="col-md-3">
                            <select class="form-control" 
                                    name="conditions[${conditionIndex}][condition_type]">
                                <option value="WHERE">WHERE</option>
                                <option value="HAVING">HAVING</option>
                                <option value="EXISTS">EXISTS</option>
                                <option value="NOT EXISTS">NOT EXISTS</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <textarea class="form-control" 
                                      name="conditions[${conditionIndex}][condition_expression]"
                                      rows="1"
                                      placeholder="Condition expression"></textarea>
                        </div>
                        <div class="col-md-2">
                            <select class="form-control" 
                                    name="conditions[${conditionIndex}][operator]">
                                <option value="AND">AND</option>
                                <option value="OR">OR</option>
                            </select>
                        </div>
                        <div class="col-md-1">
                            <button type="button" class="btn btn-danger btn-sm" onclick="removeCondition(this)">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </div>
                </div>`;
            $('#conditionsContainer').append(html);
            conditionIndex++;
        }

        function removeColumn(button) {
            $(button).closest('.column-item').remove();
        }

        function removeJoin(button) {
            $(button).closest('.join-item').remove();
        }

        function removeCondition(button) {
            $(button).closest('.condition-item').remove();
        }

        function insertFunction(func) {
            // This would insert the function into the currently focused input
            const focused = document.activeElement;
            if (focused && (focused.tagName === 'INPUT' || focused.tagName === 'TEXTAREA')) {
                const start = focused.selectionStart;
                const end = focused.selectionEnd;
                const value = focused.value;
                focused.value = value.substring(0, start) + func + value.substring(end);
                focused.selectionStart = focused.selectionEnd = start + func.length;
                focused.focus();
            }
        }

        function showTableColumns(tableName) {
            $('#modalTableName').text(tableName);
            $('#columnsTableBody').html('<tr><td colspan="4" class="text-center">Loading...</td></tr>');
            
            $.ajax({
                url: '<?= base_url("reports/get-table-columns") ?>',
                type: 'GET',
                data: { table: tableName },
                success: function(response) {
                    if (response.status === 'success') {
                        let html = '';
                        response.columns.forEach(function(column) {
                            html += `
                                <tr>
                                    <td>${column.name}</td>
                                    <td><span class="badge bg-secondary">${column.type}</span></td>
                                    <td>${column.max_length || '-'}</td>
                                    <td>
                                        <button type="button" class="btn btn-sm btn-outline-primary" 
                                                onclick="insertColumn('${tableName}.${column.name}')">
                                            <i class="fas fa-plus"></i> Insert
                                        </button>
                                    </td>
                                </tr>`;
                        });
                        $('#columnsTableBody').html(html);
                    }
                }
            });
            
            $('#columnsModal').modal('show');
        }

        function insertColumn(columnName) {
            const focused = document.activeElement;
            if (focused && (focused.tagName === 'INPUT' || focused.tagName === 'TEXTAREA')) {
                const start = focused.selectionStart;
                const end = focused.selectionEnd;
                const value = focused.value;
                focused.value = value.substring(0, start) + columnName + value.substring(end);
                focused.selectionStart = focused.selectionEnd = start + columnName.length;
                focused.focus();
            }
            $('#columnsModal').modal('hide');
        }

        function previewSql() {
            const formData = new FormData(document.getElementById('reportForm'));
            const data = {};
            formData.forEach((value, key) => {
                // Handle arrays
                if (key.includes('[')) {
                    const matches = key.match(/(\w+)\[(\d+)\]\[(\w+)\]/);
                    if (matches) {
                        const [, type, index, field] = matches;
                        if (!data[type]) data[type] = [];
                        if (!data[type][index]) data[type][index] = {};
                        data[type][index][field] = value;
                    }
                } else {
                    data[key] = value;
                }
            });

            // Convert arrays to proper format
            for (const key in data) {
                if (Array.isArray(data[key])) {
                    data[key] = data[key].filter(item => item);
                }
            }

            $.ajax({
                url: '<?= base_url("reports/preview-sql") ?>',
                type: 'POST',
                data: JSON.stringify(data),
                contentType: 'application/json',
                success: function(response) {
                    if (response.status === 'success') {
                        $('#sqlPreview').html('<pre>' + response.sql + '</pre>');
                    }
                }
            });
        }

        function saveReport() {
            const formData = new FormData(document.getElementById('reportForm'));
            
            $.ajax({
                url: '<?= base_url("reports/save") ?>',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function(response) {
                    if (response.status === 'success') {
                        alert('Report saved successfully!');
                        window.location.href = '<?= base_url("reports") ?>';
                    }
                },
                error: function(xhr) {
                    alert('Error: ' + xhr.responseText);
                }
            });
        }

        function saveAndExecute() {
            const formData = new FormData(document.getElementById('reportForm'));
            
            $.ajax({
                url: '<?= base_url("reports/save") ?>',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function(response) {
                    if (response.status === 'success') {
                        window.location.href = '<?= base_url("reports/execute") ?>/' + response.report_id;
                    }
                },
                error: function(xhr) {
                    alert('Error: ' + xhr.responseText);
                }
            });
        }
    </script>
</body>
</html>